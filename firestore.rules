rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read/write their own profile; admins can read all
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (
        request.auth.uid == userId ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin"
      );
    }

    // Authenticated users can read; staff & admin can write
    match /matters/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /clients/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /invoices/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /documents/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /timeEntries/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /messages/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /tasks/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /events/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /settings/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    // CMS collections — public read, admin write
    match /cmsPages/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /cmsBlogPosts/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /cmsAttorneys/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /cmsServices/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /cmsTestimonials/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
